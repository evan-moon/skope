{
  "name": "@evan-moon/skope",
  "version": "0.2.1",
  "mcpName": "io.github.evan-moon/skope",
  "type": "module",
  "description": "Local-first, AI-native personalized news intelligence \u2014 a lens + watcher on the world. Built-in MCP server for Claude Desktop.",
  "keywords": [
    "cli",
    "news",
    "intelligence",
    "personalization",
    "mcp",
    "claude",
    "anthropic",
    "ai",
    "local-first",
    "sqlite",
    "tavily"
  ],
  "homepage": "https://github.com/evan-moon/skope#readme",
  "bugs": {
    "url": "https://github.com/evan-moon/skope/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/evan-moon/skope.git",
    "directory": "apps/cli"
  },
  "license": "MIT",
  "author": "Evan Moon <bboydart91@gmail.com> (https://github.com/evan-moon)",
  "bin": {
    "skope": "./dist/index.js",
    "skope-mcp": "./dist/mcp.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup && yarn workspace @skope/mcp build && cp ../mcp/dist/index.js dist/mcp.js && cp ../../README.md README.md && cp ../../LICENSE LICENSE",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "better-sqlite3": "^12.9.0",
    "commander": "^13.1.0",
    "drizzle-orm": "^0.45.2",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@skope/db": "workspace:*",
    "@skope/domain": "workspace:*",
    "@skope/profile": "workspace:*",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.3",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
