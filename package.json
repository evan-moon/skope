{
  "name": "skope",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*/*"
  ],
  "scripts": {
    "dev": "yarn workspace @evan-moon/skope dev",
    "dev:cli": "yarn workspace @evan-moon/skope dev",
    "dev:mcp": "yarn workspace @skope/mcp dev",
    "dev:docs": "yarn workspace @skope/docs dev",
    "typecheck": "turbo typecheck",
    "build": "turbo build",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3",
    "vitest": "^4.1.5"
  },
  "packageManager": "yarn@4.14.1"
}
